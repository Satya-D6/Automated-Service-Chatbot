# ============================================================
# UniAssist — ServiceNow PDI Environment Variables
# Copy this file to .env and fill in your PDI details.
# NEVER commit .env to version control.
# ============================================================

# Your ServiceNow PDI base URL (no trailing slash)
VITE_SN_INSTANCE=https://devXXXXX.service-now.com

# ServiceNow credentials (use a dedicated integration user, not admin)
VITE_SN_USER=admin
VITE_SN_PASS=your_password_here

# sys_id of the Assignment Group for university admin requests
# Find it: ServiceNow → Groups → your group → copy sys_id from URL
VITE_SN_GROUP=
